{
  "expo": {
    "name": "ExpenseZ",
    "slug": "ExpenseZ",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ExpenseZ",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/expensez-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#050505"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#050505"
      },
      "package": "com.princedubey1998.ExpenseZ",
      "versionCode": 1,
      "permissions": [],
      "playStoreConfig": {
        "storeUrl": "https://play.google.com/store/apps/details?id=com.princedubey1998.ExpenseZ"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0fe7bb60-1503-40e1-a0bd-c06d46e52321"
      }
    }
  }
}
